<odoo>

    <!-- Action to trigger the import wizard -->
    <record id="action_import_lots_wizard" model="ir.actions.act_window">
        <field name="name">Import Lots</field>
        <field name="res_model">import.lot.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_move_id': active_id}</field>
    </record>

    <!-- Inherit stock move operations view -->
    <record id="view_stock_move_form_inherit_import_button" model="ir.ui.view">
        <field name="name">stock.move.form.inherit.import.button</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_stock_move_operations"/>
        <field name="arch" type="xml">

            <!-- Insert our button inside the button container -->
            <xpath expr="//div[@class='d-flex']" position="inside">
                <button name="%(action_import_lots_wizard)d"
                        type="action"
                        string="Import Excel"
                        class="btn btn-link btn-group"
                        context="{'default_move_id': id}"/>
            </xpath>

        </field>
    </record>

</odoo>
