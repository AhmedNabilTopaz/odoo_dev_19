<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Report Action -->
    <record id="action_report_journal_lines" model="ir.actions.report">
        <field name="name">Journal Lines Report</field>
        <field name="model">watan.journal.print.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">watan_journal_print.report_journal_lines_template</field>
        <field name="report_file">watan_journal_print.report_journal_lines_template</field>
        <field name="print_report_name">'Journal Lines - %s' % (object.company_id.name)</field>
        <field name="binding_model_id" ref="account.model_account_move_line"/>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <!-- QWeb PDF Template -->
    <template id="report_journal_lines_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wizard">
                <t t-call="web.internal_layout">
                    <div class="page">

                        <!-- Title -->
                        <h2 style="text-align:center; margin-bottom:4px;">
                            Journal Lines Report
                        </h2>
                        <p style="text-align:center; color:#666; margin-top:0;">
                            <t t-if="wizard.date_from">
                                From: <strong><t t-esc="wizard.date_from"/></strong>
                            </t>
                            <t t-if="wizard.date_to">
                                &amp;nbsp;&amp;nbsp;To: <strong><t t-esc="wizard.date_to"/></strong>
                            </t>
                            &amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;
                            Company: <strong><t t-esc="wizard.company_id.name"/></strong>
                        </p>

                        <hr/>

                        <!-- Lines Table -->
                        <table class="table table-sm table-bordered" style="font-size:11px; width:100%;">
                            <thead style="background-color:#f0f0f0;">
                                <tr>
                                    <th>Date</th>
                                    <th>Entry</th>
                                    <th>Journal</th>
                                    <th>Account</th>
                                    <th>Label</th>
                                    <th>Partner</th>
                                    <th class="text-right">Debit</th>
                                    <th class="text-right">Credit</th>
                                    <th class="text-right">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="wizard.line_ids" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.date"/></td>
                                        <td><t t-esc="line.move_id.name"/></td>
                                        <td><t t-esc="line.journal_id.name"/></td>
                                        <td><t t-esc="line.account_id.code"/> - <t t-esc="line.account_id.name"/></td>
                                        <td><t t-esc="line.name"/></td>
                                        <td><t t-esc="line.partner_id.name or ''"/></td>
                                        <td class="text-right">
                                            <t t-if="line.debit">
                                                <t t-esc="'%.2f' % line.debit"/>
                                            </t>
                                        </td>
                                        <td class="text-right">
                                            <t t-if="line.credit">
                                                <t t-esc="'%.2f' % line.credit"/>
                                            </t>
                                        </td>
                                        <td class="text-right">
                                            <t t-esc="'%.2f' % (line.debit - line.credit)"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <!-- Totals Row -->
                            <tfoot style="background-color:#f0f0f0; font-weight:bold;">
                                <tr>
                                    <td colspan="6" class="text-right">Total</td>
                                    <td class="text-right">
                                        <t t-esc="'%.2f' % sum(wizard.line_ids.mapped('debit'))"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'%.2f' % sum(wizard.line_ids.mapped('credit'))"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'%.2f' % sum(d - c for d, c in zip(wizard.line_ids.mapped('debit'), wizard.line_ids.mapped('credit')))"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Footer note -->
                        <p style="font-size:10px; color:#888; margin-top:16px;">
                            Total lines: <t t-esc="len(wizard.line_ids)"/>
                            &amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;
                            Printed on: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                        </p>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
