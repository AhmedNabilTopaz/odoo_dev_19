<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Report Action -->
    <record id="action_report_journal_summary" model="ir.actions.report">
        <field name="name">Journal Account Summary</field>
        <field name="model">watan.journal.summary.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">watan_journal_print.report_journal_summary_template</field>
        <field name="report_file">watan_journal_print.report_journal_summary_template</field>
        <field name="print_report_name">'Journal Summary - %s' % object.company_id.name</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <!-- QWeb PDF Document Sub-Template -->
    <template id="report_journal_summary_document">
        <t t-call="web.internal_layout">
            <t t-set="wiz" t-value="wiz.with_context(lang=wiz.env.context.get('lang'))"/>
            <div class="page">

                <!-- Report Header -->
                <div style="text-align:center; margin-bottom:20px;">
                    <h2 style="margin-bottom:4px;">Journal Account Summary</h2>
                    <h3 style="margin-top:0; color:#444;">
                        <t t-esc="wiz.company_id.name"/>
                    </h3>
                    <p style="color:#666; font-size:12px; margin:0;">
                        <span>Period:</span>
                        <strong>
                            <t t-esc="wiz.date_from"/>
                        </strong>
                        &amp;nbsp;→&amp;nbsp;
                        <strong>
                            <t t-esc="wiz.date_to"/>
                        </strong>
                        &amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;
                        <span>Filter: Accounts containing</span>
                        <strong>إيزي</strong>
                    </p>
                </div>

                <hr style="margin-bottom:16px;"/>

                <!-- Accounts Table -->
                <table style="width:100%; border-collapse:collapse; font-size:11px;">
                    <thead>
                        <tr style="background-color:#2c3e50; color:white;">
                            <th style="padding:7px 10px; text-align:left; width:12%;">Code</th>
                            <th style="padding:7px 10px; text-align:left; width:40%;">Account Name</th>
                            <th style="padding:7px 10px; text-align:right; width:16%;">Debit (SR)</th>
                            <th style="padding:7px 10px; text-align:right; width:16%;">Credit (SR)</th>
                            <th style="padding:7px 10px; text-align:right; width:16%;">Balance (SR)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="wiz.summary_line_ids" t-as="line">
                            <tr t-attf-style="background-color: {{ '#f9f9f9' if line_index % 2 == 0 else 'white' }};">
                                <td style="padding:6px 10px; border-bottom:1px solid #e0e0e0;">
                                    <t t-esc="line.account_code"/>
                                </td>
                                <td style="padding:6px 10px; border-bottom:1px solid #e0e0e0;">
                                    <t t-esc="line.account_name"/>
                                </td>
                                <td style="padding:6px 10px; text-align:right; border-bottom:1px solid #e0e0e0;">
                                    <t t-esc="'{:,.2f}'.format(line.total_debit)"/>
                                </td>
                                <td style="padding:6px 10px; text-align:right; border-bottom:1px solid #e0e0e0;">
                                    <t t-esc="'{:,.2f}'.format(line.total_credit)"/>
                                </td>
                                <td t-attf-style="padding:6px 10px; text-align:right; border-bottom:1px solid #e0e0e0; color: {{ 'green' if line.balance >= 0 else 'red' }};">
                                    <t t-esc="'{:,.2f}'.format(line.balance)"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>

                    <!-- Totals Footer -->
                    <tfoot>
                        <tr style="background-color:#2c3e50; color:white; font-weight:bold;">
                            <td colspan="2" style="padding:8px 10px;">
                                <span>TOTAL</span>
                                (
                                <t t-esc="len(wiz.summary_line_ids)"/>
                                <span>accounts</span>)
                            </td>
                            <td style="padding:8px 10px; text-align:right;">
                                <t t-esc="'{:,.2f}'.format(sum(wiz.summary_line_ids.mapped('total_debit')))"/>
                            </td>
                            <td style="padding:8px 10px; text-align:right;">
                                <t t-esc="'{:,.2f}'.format(sum(wiz.summary_line_ids.mapped('total_credit')))"/>
                            </td>
                            <td style="padding:8px 10px; text-align:right;">
                                <t t-esc="'{:,.2f}'.format(sum(wiz.summary_line_ids.mapped('total_debit')) - sum(wiz.summary_line_ids.mapped('total_credit')))"/>
                            </td>
                        </tr>
                    </tfoot>
                </table>

                <!-- Footer note -->
                <p style="font-size:9px; color:#aaa; margin-top:20px; text-align:right;">
                    <span>Generated:</span>
                    <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                    &amp;nbsp;|&amp;nbsp;
                    <span>Posted entries only</span>
                </p>

            </div>
        </t>
    </template>

    <!-- QWeb PDF Main Template -->
    <template id="report_journal_summary_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wiz">
                <t t-set="lang" t-value="wiz.env.context.get('lang') or wiz.env.user.lang"/>
                <t t-call="watan_journal_print.report_journal_summary_document" t-lang="lang"/>
            </t>
        </t>
    </template>

</odoo>
