<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Separate list view for account.move.line used inside the wizard.
         Defined outside the wizard's form arch so Odoo validates its fields
         against account.move.line (the comodel) instead of the wizard model. -->
    <record id="view_journal_wizard_aml_list" model="ir.ui.view">
        <field name="name">watan.journal.wizard.aml.list</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="date"/>
                <field name="move_id"/>
                <field name="journal_id"/>
                <field name="account_id"/>
                <field name="name"/>
                <field name="debit"/>
                <field name="credit"/>
            </list>
        </field>
    </record>

    <!-- Wizard Form View -->
    <record id="view_journal_print_wizard_form" model="ir.ui.view">
        <field name="name">watan.journal.print.wizard.form</field>
        <field name="model">watan.journal.print.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Journal Lines">
                <group>
                    <field name="allowed_company_ids" invisible="1"/>
                    <field name="company_id" domain="[('id', 'in', allowed_company_ids)]"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <group string="Selected Lines">
                    <field name="line_ids" nolabel="1" readonly="1"
                           context="{'list_view_ref': 'watan_journal_print.view_journal_wizard_aml_list'}"/>
                </group>
                <footer>
                    <button name="action_print_pdf"
                            string="Print PDF"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Server Action: appears in Action menu of Journal Items list -->
    <record id="action_journal_lines_print_wizard" model="ir.actions.server">
        <field name="name">Print Selected Lines (PDF)</field>
        <field name="model_id" ref="account.model_account_move_line"/>
        <field name="binding_model_id" ref="account.model_account_move_line"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Print Journal Lines',
    'res_model': 'watan.journal.print.wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': {
        'active_ids': env.context.get('active_ids', []),
        'active_model': 'account.move.line',
    },
}
        </field>
    </record>

</odoo>
