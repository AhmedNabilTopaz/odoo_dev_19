<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard Form View -->
    <record id="view_journal_summary_wizard_form" model="ir.ui.view">
        <field name="name">watan.journal.summary.wizard.form</field>
        <field name="model">watan.journal.summary.wizard</field>
        <field name="arch" type="xml">
            <form string="Journal Account Summary">
                <group>
                    <group>
                    <!-- Hidden field that feeds the domain -->
                    <field name="allowed_company_ids" invisible="1"/>
                    
                    <!-- Now domain references the stored field, not the context -->
                    <field name="company_id" domain="[('id', 'in', allowed_company_ids)]"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </group>

                <!-- Preview table (shown after clicking Load) -->
                <field name="summary_line_ids" nolabel="1" readonly="1">
                    <list>
                        <field name="account_code" string="Code"/>
                        <field name="account_name" string="Account"/>
                        <field name="total_debit"  string="Debit"   sum="Total Debit"/>
                        <field name="total_credit" string="Credit"  sum="Total Credit"/>
                        <field name="balance"      string="Balance" sum="Total Balance"/>
                    </list>
                </field>

                <footer>
                    <button name="action_preview"
                            string="Load Preview"
                            type="object"
                            class="btn-secondary"/>
                    <button name="action_print_pdf"
                            string="Print PDF"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Menu Action to open the wizard -->
    <record id="action_open_journal_summary_wizard" model="ir.actions.act_window">
        <field name="name">Journal Account Summary</field>
        <field name="res_model">watan.journal.summary.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Add to Accounting > Reporting menu -->
    <menuitem
        id="menu_watan_journal_summary"
        name="Journal Account Summary (eZee)"
        parent="odoo_ezee_pms_integration.menu_pms_integration_root"
        action="action_open_journal_summary_wizard"
        sequence="99"/>

</odoo>
