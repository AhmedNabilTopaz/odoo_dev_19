<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Stock Picking Form View -->
    <record id="view_picking_form_inherit_allegro" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.allegro</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Add fields after the scheduled date -->
            <xpath expr="//field[@name='picking_type_id']" position="after">
                <field name="driver_name"/>
                <field name="car_number"/>
                <field name="national_number"/>
            </xpath>
        </field>
    </record>
</odoo>