<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_config_inherit_vending_machine" model="ir.ui.view">
        <field name="name">pos.config.inherit.vending.machine</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Inserting after the Inventory block which has id="pos_inventory_section" -->
            <xpath expr="//block[@id='pos_inventory_section']" position="after">
                <block title="Vending Machine" id="pos_vending_section">
                    <setting string="Vending Machine" help="Link this Point of Sale to a specific vending machine.">
                        <field name="vending_machine_id"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>