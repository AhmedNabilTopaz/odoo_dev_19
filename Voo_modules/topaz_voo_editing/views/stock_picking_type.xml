<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_type_form_inherit_topaz"
            model="ir.ui.view">
        <field name="name">view_picking_type_form_inherit_topaz</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='code']"
                   position="after">
                <field name="is_expense"/>
            </xpath>

        </field>
    </record>
</odoo>
