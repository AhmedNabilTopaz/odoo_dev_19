<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_stock_history_search_inherit_topaz" model="ir.ui.view">
        <field name="name">stock.history.search.inherit.topaz</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.stock_move_line_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search/group[@name='groupby']/filter[@name='groupby_product_id']" position="after">
                <filter string="Vendor" name="by_vendor" domain="[]" context="{'group_by': 'vendor_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>
