<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="quant_search_view_inherit_topaz" model="ir.ui.view">
        <field name="name">quant_search_view_inherit_topaz</field>
        <field name="model">stock.quant</field>
        <field name="priority">1</field>
        <field name="inherit_id" ref="stock.quant_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//search/group[2]" position="inside">
                <filter string='Barcode' name="barcodegroup" context="{'group_by': 'barcode'}"/>
                <filter string='Product Tags' name="product_tagsgroup" context="{'group_by': 'product_tags'}"/>
                <filter string="Status" name="status_topazgroup" context="{'group_by': 'status_topaz'}"/>
                <filter string="Vendor" name="vendorgroup" context="{'group_by': 'vendor_ids'}"/>

            </xpath>

        </field>
    </record>
    <record id="view_stock_quant_tree_inventory_editable_inherit_topaz" model="ir.ui.view">
        <field name="name">view_stock_quant_tree_inventory_editable_inherit_topaz</field>
        <field name="model">stock.quant</field>
        <field name="priority">1</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_inventory_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="barcode" optional="hidden"/>
                <field name="product_tags" optional="hidden"/>
            </xpath>

        </field>
    </record>
</odoo>