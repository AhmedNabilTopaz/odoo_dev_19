<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_ezee_payment_status" model="ir.ui.view">
        <field name="name">account.move.ezee.payment.status</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@id='other_tab_entry']//field[@name='company_id']" position="after">
                <field name="ezee_payment_status"
                       readonly="1"
                       widget="badge"
                       decoration-success="ezee_payment_status == 'paid'"
                       decoration-warning="ezee_payment_status == 'unpaid'"/>
                <field name="ezee_balance"
                       readonly="1"
                       invisible="ezee_payment_status == 'paid'"/>
            </xpath>
        </field>
    </record>
</odoo>