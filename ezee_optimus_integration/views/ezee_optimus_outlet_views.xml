<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ezee_optimus_outlet_tree" model="ir.ui.view">
        <field name="name">ezee.optimus.outlet.tree</field>
        <field name="model">ezee.optimus.outlet</field>
        <field name="arch" type="xml">
            <list string="eZee Optimus Outlets" editable="bottom">
                <field name="hotel_id" readonly="1"/>
                <field name="ezee_outlet_id" readonly="1"/>
                <field name="name" readonly="1"/>
                <field name="sales_journal_id"/>
                <field name="purchase_journal_id"/>
                <field name="analytic_account_id"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_ezee_optimus_outlets" model="ir.actions.act_window">
        <field name="name">Optimus Outlets</field>
        <field name="res_model">ezee.optimus.outlet</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
    </record>
    
    <menuitem id="menu_ezee_optimus_outlets"
              name="Outlets"
              parent="menu_ezee_optimus_root"
              action="action_ezee_optimus_outlets"
              groups="ezee_optimus_integration.group_ezee_optimus_gateway_manager"
              sequence="15"/>
</odoo>
