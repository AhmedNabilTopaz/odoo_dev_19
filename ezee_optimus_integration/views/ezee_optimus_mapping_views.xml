<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ezee_optimus_mapping_list" model="ir.ui.view">
        <field name="name">ezee.optimus.account.mapping.list</field>
        <field name="model">ezee.optimus.account.mapping</field>
        <field name="arch" type="xml">
            <list editable="bottom" open_form_view="1">
                <field name="hotel_id"/>
                <field name="header_name"/>
                <field name="header_id"/>
                <field name="account_group_id"/>
                <field name="account_id"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_ezee_optimus_mapping_form" model="ir.ui.view">
        <field name="name">ezee.optimus.account.mapping.form</field>
        <field name="model">ezee.optimus.account.mapping</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="hotel_id"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="header_name"/>
                            <field name="header_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="account_group_id"/>
                            <field name="account_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Detailed Lines">
                            <field name="line_ids" context="{'default_mapping_id': id}">
                                <list editable="bottom">
                                    <field name="ezee_desc_unk_id"/>
                                    <field name="description"/>
                                    <field name="desc_type_id"/>
                                    <field name="desc_type_name"/>
                                    <field name="account_id"/>
                                    <field name="analytic_account_id"/>
                                    <field name="company_id" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ezee_optimus_mapping_search" model="ir.ui.view">
        <field name="name">ezee.optimus.account.mapping.search</field>
        <field name="model">ezee.optimus.account.mapping</field>
        <field name="arch" type="xml">
            <search>
                <field name="hotel_id"/>
                <field name="header_name"/>
                <field name="header_id"/>
                <filter string="Missing Odoo Account" name="missing_account" domain="[('account_id', '=', False)]"/>
                <filter string="Hotel" name="group_by_hotel" context="{'group_by': 'hotel_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_ezee_optimus_mapping_line_list" model="ir.ui.view">
        <field name="name">ezee.optimus.account.mapping.line.list</field>
        <field name="model">ezee.optimus.account.mapping.line</field>
        <field name="arch" type="xml">
            <list string="Mapping Lines" editable="bottom" create="0">
                <field name="mapping_id" readonly="1" optional="show"/>
                <field name="desc_type_id" readonly="1" optional="hide"/>
                <field name="desc_type_name" readonly="1"/>
                <field name="ezee_desc_unk_id" readonly="1" optional="hide"/>
                <field name="description" readonly="1"/>
                <field name="account_id"/>
                <field name="analytic_account_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_ezee_optimus_mapping_line_search" model="ir.ui.view">
        <field name="name">ezee.optimus.account.mapping.line.search</field>
        <field name="model">ezee.optimus.account.mapping.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="mapping_id"/>
                <field name="description"/>
                <field name="ezee_desc_unk_id"/>
                <filter string="Missing Account" name="missing_account" domain="[('account_id', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_ezee_optimus_mapping" model="ir.actions.act_window">
        <field name="name">Account Mapping</field>
        <field name="res_model">ezee.optimus.account.mapping</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        <field name="context">{'allowed_company_ids': allowed_company_ids}</field>
    </record>

    <menuitem id="menu_ezee_optimus_mapping"
              name="Account Mapping"
              parent="menu_ezee_optimus_root"
              action="action_ezee_optimus_mapping"
              groups="ezee_optimus_integration.group_ezee_optimus_gateway_manager"
              sequence="20"/>

</odoo>
