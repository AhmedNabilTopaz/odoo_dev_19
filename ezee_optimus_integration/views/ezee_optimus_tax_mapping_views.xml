<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ezee_optimus_tax_mapping_list" model="ir.ui.view">
        <field name="name">ezee.optimus.tax.mapping.list</field>
        <field name="model">ezee.optimus.tax.mapping</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="hotel_id"/>
                <field name="tax_id"/>
                <field name="tax_name"/>
                <field name="odoo_tax_id"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_ezee_optimus_tax_mapping_form" model="ir.ui.view">
        <field name="name">ezee.optimus.tax.mapping.form</field>
        <field name="model">ezee.optimus.tax.mapping</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="hotel_id"/>
                            <field name="tax_id"/>
                            <field name="tax_name"/>
                        </group>
                        <group>
                            <field name="odoo_tax_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ezee_optimus_tax_mapping_search" model="ir.ui.view">
        <field name="name">ezee.optimus.tax.mapping.search</field>
        <field name="model">ezee.optimus.tax.mapping</field>
        <field name="arch" type="xml">
            <search>
                <field name="hotel_id"/>
                <field name="tax_id"/>
                <field name="tax_name"/>
                <field name="odoo_tax_id"/>
                <filter string="Missing Odoo Tax" name="missing_odoo_tax" domain="[('odoo_tax_id', '=', False)]"/>
                <filter string="Hotel" name="group_by_hotel" context="{'group_by': 'hotel_id'}"/>
                <filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_ezee_optimus_tax_mapping" model="ir.actions.act_window">
        <field name="name">Tax Mapping</field>
        <field name="res_model">ezee.optimus.tax.mapping</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        <field name="context">{'search_default_missing_odoo_tax': 1}</field>
    </record>

    <menuitem id="menu_ezee_optimus_tax_mapping"
              name="Tax Mapping"
              parent="menu_ezee_optimus_root"
              action="action_ezee_optimus_tax_mapping"
              groups="ezee_optimus_integration.group_ezee_optimus_gateway_manager"
              sequence="30"/>
</odoo>
