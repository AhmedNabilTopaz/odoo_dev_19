<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ezee_optimus</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='account_vendor_bills']" position="after">
                <block title="eZee Optimus POS Integration" id="ezee_optimus_settings">
                    <setting id="ezee_optimus_company_id"
                             string="Company ID"
                             help="Optimus company ID used as comanyunkid in the Xero account interface API.">
                        <field name="optimus_company_id" placeholder="59557"/>
                    </setting>
                    <setting id="ezee_optimus_base_url"
                             string="API URL"
                             help="Endpoint for the Optimus Xero account interface API.">
                        <field name="optimus_base_url" class="w-100"/>
                    </setting>
                    <setting id="ezee_optimus_auth_code"
                             string="Auth Code"
                             help="Authentication code provided by eZee for the Optimus Xero account interface API.">
                        <field name="optimus_auth_code"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>