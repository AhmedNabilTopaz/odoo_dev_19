<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ezee_optimus</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='account_vendor_bills']" position="after">
                <block title="eZee Optimus POS Integration" id="ezee_optimus_settings">
                    <setting id="ezee_optimus_hotel_code"
                             string="Hotel Code"
                             help="Hotel code provided by eZee Optimus for API access.">
                        <field name="optimus_hotel_code" placeholder="XXXX"/>
                    </setting>
                    <setting id="ezee_optimus_username"
                             string="Username"
                             help="API username used for HTTP Basic authentication.">
                        <field name="optimus_username" placeholder="eZee API username"/>
                    </setting>
                    <setting id="ezee_optimus_password"
                             string="Password"
                             help="API password used for HTTP Basic authentication.">
                        <field name="optimus_password" password="True" placeholder="eZee API password"/>
                    </setting>
                    <setting id="ezee_optimus_base_url"
                             string="Base URL"
                             help="Base endpoint for the eZee Optimus FAS APIs.">
                        <field name="optimus_base_url" class="w-100"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
