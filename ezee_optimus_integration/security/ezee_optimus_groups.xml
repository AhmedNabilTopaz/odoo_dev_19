<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record model="res.groups.privilege" id="res_groups_privilege_ezee_optimus_gateway">
            <field name="name">eZee Optimus Gateway</field>
            <field name="sequence">10</field>
            <field name="category_id" ref="base.module_category_accounting"/>
        </record>

        <record id="group_ezee_optimus_gateway_user" model="res.groups">
            <field name="name">User</field>
            <field name="sequence">10</field>
            <field name="privilege_id" ref="res_groups_privilege_ezee_optimus_gateway"/>
            <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
            <field name="comment">Read-only access to eZee Optimus Gateway records and logs.</field>
        </record>

        <record id="group_ezee_optimus_gateway_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="sequence">20</field>
            <field name="privilege_id" ref="res_groups_privilege_ezee_optimus_gateway"/>
            <field name="implied_ids" eval="[(6, 0, [ref('group_ezee_optimus_gateway_user')])]"/>
            <field name="comment">Full access to eZee Optimus Gateway configuration and synchronization.</field>
        </record>
    </data>
</odoo>
