<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Account Mapping -->
    <record id="view_pms_account_mapping_tree" model="ir.ui.view">
        <field name="name">pms.account.mapping.tree</field>
        <field name="model">pms.account.mapping</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="hotel_id"/>
                <!-- <field name="hotel_id_code"/> -->
                <!-- <field name="pms_account_name"/> -->
                <!-- <field name="pms_account_id"/> -->
                <!-- <field name="pms_account_type_name"/> -->
                <!-- <field name="pms_account_type_id"/> -->
                <field name="pms_account_header_name"/>
                <field name="pms_account_header_id"/>
                <field name="account_group_id"/>
                <field name="account_id"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="action_pms_account_mapping" model="ir.actions.act_window">
        <field name="name">Account Mapping</field>
        <field name="res_model">pms.account.mapping</field>
        <field name="view_mode">list</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        <field name="context">{'allowed_company_ids': allowed_company_ids}</field>
    </record>

    <!-- Tax Mapping -->
    <record id="view_pms_tax_mapping_tree" model="ir.ui.view">
        <field name="name">pms.tax.mapping.tree</field>
        <field name="model">pms.tax.mapping</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="hotel_id"/>
                <field name="pms_tax_id"/>
                <field name="pms_tax_name"/>
                <field name="tax_id"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="action_pms_tax_mapping" model="ir.actions.act_window">
        <field name="name">Tax Mapping</field>
        <field name="res_model">pms.tax.mapping</field>
        <field name="view_mode">list</field>
                <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        <field name="context">{'allowed_company_ids': allowed_company_ids}</field>
    </record>

