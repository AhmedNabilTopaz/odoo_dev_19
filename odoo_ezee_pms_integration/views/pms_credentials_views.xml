<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pms_credentials_form" model="ir.ui.view">
        <field name="name">pms.credentials.form</field>
        <field name="model">pms.credentials</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_connection" string="Test Connection" type="object" class="oe_highlight"/>
                    <button name="action_pull_config" string="Pull Master Data" type="object"/>
                </header>
                <sheet>
                    <group>
                        <group string="API Credentials">
                            <field name="name"/>
                            <field name="hotel_code"/>
                            <field name="username"/>
                            <field name="password" password="True"/>
                        </group>
                        <group string="Odoo Configuration">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="analytic_account_id" invisible="1"/>
                            <field name="journal_id"/>
                             <field name="debt_transfer_journal_id"/>

                            <field name="active"/>
                        </group>
                    </group>
                    <group string="PMS Environment">
                        <group>
                            <field name="auth_code"/>
                            <field name="working_date"/>
                            <field name="currency_code"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pms_credentials_tree" model="ir.ui.view">
        <field name="name">pms.credentials.tree</field>
        <field name="model">pms.credentials</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="hotel_code"/>
                <field name="journal_id"/>
                <field name="debt_transfer_journal_id"/>
                <field name="working_date"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="action_pms_credentials" model="ir.actions.act_window">
        <field name="name">PMS Configuration</field>
        <field name="res_model">pms.credentials</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        <field name="context">{'allowed_company_ids': allowed_company_ids}</field>
    </record>
</odoo>
