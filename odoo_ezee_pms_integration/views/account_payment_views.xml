<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Payment Form View -->
    <record id="view_payment_form_inherit_pms" model="ir.ui.view">
        <field name="name">account.payment.form.inherit.pms</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
             <xpath expr="//sheet/group[1]/group[2]/field[@name='payment_method_line_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath> 
            <!-- <xpath expr="//sheet/group[1]/group[2]/div[2]/field[@name='journal_id']" position="after">
                 
            </xpath> -->
            <xpath expr="//sheet" position="inside">
                <notebook invisible="not pms_tran_id">
                    <page string="PMS Integration" name="pms_integration">
                        <group name="pms_header">
                            <group string="Reservation Information">
                                <field name="pms_hotel_id" readonly="1"/>
                                <field name="ezee_reservation_number" readonly="1"/>
                                <field name="ezee_room_number" readonly="1"/>
                                <field name="ezee_checkin_date" readonly="1"/>
                                <field name="ezee_checkout_date" readonly="1"/>
                                <field name="bussiness_source_name" readonly="1"/>
                            </group>
                             <group string="PMS Payment">
                                <field name="ezee_receipt_no" readonly="1"/>
                                <field name="ezee_voucher_type" readonly="1"/>
                                  <field name="pms_tran_id" readonly="1"/>
                                <field name="ezee_folio_number" readonly="1"/>
                                <field name="ezee_payment_method" readonly="1"/>
                                <field name="market" readonly="1"/>
                                
                            </group>
                             <group string="Voucher &amp; Credit">
                                <field name="ezee_bill_name" readonly="1"/>
                                <field name="ezee_voucher_number" readonly="1"/>
                                <field name="ezee_credit_number" readonly="1"/>
                            </group>
                            <!-- <group>
                                <field name="ezee_id" readonly="1"/>
                                <field name="ezee_guest_name" readonly="1"/>
                                
                            </group> -->
                           
                           
                            
                             <!-- <group string="PMS Payment">
                                <field name="ezee_type" readonly="1"/>
                                <field name="pms_reference" readonly="1"/>
                                <field name="ezee_invoice_no" readonly="1"/>
                                <field name="ezee_amount" readonly="1"/>
                            </group> -->
                           
                            <!-- <group string="Remarks">
                                <field name="remarks" readonly="1" nolabel="1" colspan="2"/>
                            </group> -->
                        </group>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>

    <!-- Inherit Payment Tree View -->
    <record id="view_payment_tree_inherit_pms" model="ir.ui.view">
        <field name="name">account.payment.tree.inherit.pms</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='payment_method_line_id']" position="attributes">
                 <attribute name="column_invisible">1</attribute>
            </xpath> 
            <!-- Add PMS Hotel column after name field -->
            <field name="name" position="after">
                <field name="pms_hotel_id" optional="hide"/>
                <field name="pms_reference" optional="hide"/>
            </field>
        </field>
    </record>

    <!-- Add search filters -->
    <record id="view_account_payment_filter_inherit_pms" model="ir.ui.view">
        <field name="name">account.payment.search.inherit.pms</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_search"/>
        <field name="arch" type="xml">
            <!-- Add PMS search fields -->
            <search>
                <field name="pms_hotel_id"/>
                <field name="pms_tran_id"/>
                <field name="pms_reference"/>
            </search>
        </field>
    </record>
</odoo>
