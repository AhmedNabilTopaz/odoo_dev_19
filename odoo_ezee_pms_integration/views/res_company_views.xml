<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_company_form_inherit_hotel_id" model="ir.ui.view">
		<field name="name">res.company.form.inherit.hotel_id</field>
		<field name="model">res.company</field>
		<field name="inherit_id" ref="base.view_company_form"/>
		<field name="arch" type="xml">
			<xpath expr="//form/sheet/notebook/page[1]/group[1]/group[1]/field[@name='company_registry']" position="after">
				<field name="hotel_id"/>
			</xpath>
		</field>
	</record>
</odoo>
