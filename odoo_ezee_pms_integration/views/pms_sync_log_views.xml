<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pms_sync_log_tree" model="ir.ui.view">
        <field name="name">pms.sync.log.tree</field>
        <field name="model">pms.sync.log</field>
        <field name="arch" type="xml">
            <list create="false" edit="false">
                <field name="create_date" string="Sync Time"/>
                <field name="hotel_id"/>
                <field name="api_type"/>
                <field name="sync_date"/>
                <field name="sync_date_to"/>
                <field name="status" widget="badge" decoration-success="status == 'success'" decoration-danger="status == 'failed'"/>
            </list>
        </field>
    </record>

    <record id="view_pms_sync_log_form" model="ir.ui.view">
        <field name="name">pms.sync.log.form</field>
        <field name="model">pms.sync.log</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="hotel_id"/>
                            <field name="api_type"/>
                            <field name="sync_date"/>
                            <field name="sync_date_to"/>

                        </group>
                        <group>
                            <field name="status"/>
                            <field name="create_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Request">
                            <field name="request_payload"/>
                        </page>
                        <page string="Response">
                            <field name="response_payload"  options="{'mode': 'json'}" />
                        </page>
                        <page string="Error" invisible="not error_message">
                            <field name="error_message"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pms_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">pms.sync.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
