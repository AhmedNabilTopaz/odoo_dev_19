<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_pms_sync_all" model="ir.cron">
        <field name="name">PMS: Scheduled Sync (All Hotels)</field>
        <field name="model_id" ref="model_pms_credentials"/>
        <field name="state">code</field>
        <field name="code">model.search([]).action_scheduled_sync()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).replace(hour=10, minute=0, second=0)"/>
        <field name="active" eval="True"/>
    </record>
</odoo>
