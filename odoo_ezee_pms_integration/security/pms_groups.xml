<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        noupdate="0" ensures Odoo re-applies these records on every upgrade.
        Without this, changes to privilege_id / implied_ids are silently ignored
        after the first install.
        Once mutual-exclusivity is confirmed working you may set it back to "1".
    -->
    <data noupdate="0">
        <!-- PMS Integration Privilege
             All groups sharing this privilege_id appear as a radio-button
             selector (mutually exclusive) on the user form under Accounting. -->
        <record model="res.groups.privilege" id="res_groups_privilege_pms_integration">
            <field name="name">PMS Integration</field>
            <field name="sequence">5</field>
            <field name="category_id" ref="base.module_category_accounting"/>
        </record>

        <!-- PMS Integration User Group - read-only access -->
        <record id="group_pms_integration_user" model="res.groups">
            <field name="name">User</field>
            <field name="sequence">10</field>
            <field name="privilege_id" ref="res_groups_privilege_pms_integration"/>
            <!-- (6, 0, [...]) replaces the full list, avoiding stale (4,...) appends -->
            <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
            <field name="comment">User with read-only access to PMS Integration features</field>
        </record>

        <!-- PMS Integration Manager Group - full access, implies User above -->
        <record id="group_pms_integration_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="sequence">20</field>
            <field name="privilege_id" ref="res_groups_privilege_pms_integration"/>
            <field name="implied_ids" eval="[(6, 0, [ref('group_pms_integration_user')])]"/>
            <field name="comment">Administrator with full access to PMS Integration features</field>
        </record>
    </data>
</odoo>
