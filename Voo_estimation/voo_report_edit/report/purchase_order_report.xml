<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Purchase Order Report -->
    <template id="report_purchaseorder_document_inherit" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//t[@t-if='o.dest_address_id']" position="replace">
            <t t-if="o.picking_type_id.default_location_dest_id">
                <t t-set="information_block">
                    <strong>Shipping Address:</strong>
                    <div>
                        <span t-field="o.picking_type_id.default_location_dest_id.display_name"/>
                    </div>
                </t>
            </t>
        </xpath>
    </template>

    <!-- Purchase Quotation Report -->
    <template id="report_purchasequotation_document_inherit" inherit_id="purchase.report_purchasequotation_document">
        <xpath expr="//t[@t-if='o.dest_address_id']" position="replace">
            <t t-if="o.picking_type_id.default_location_dest_id">
                <t t-set="information_block">
                    <strong>Shipping Address:</strong>
                    <div>
                        <span t-field="o.picking_type_id.default_location_dest_id.display_name"/>
                    </div>
                </t>
            </t>
        </xpath>
    </template>

