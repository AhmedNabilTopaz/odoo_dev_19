<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Inherit the purchase order form -->
    <record id="view_purchase_order_form_inherit_topaz" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.topaz</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Add received amount fields to order lines tree
                 Anchor on price_subtotal — always present in Odoo 19 order_line tree -->
            <xpath expr="//field[@name='order_line']/list/field[@name='price_subtotal']" position="after">
                <field name="sub_total_received" optional="show" widget="monetary"/>
                <field name="product_barcode" optional="show"/>
            </xpath>

            <!-- Add received total fields after the tax_totals widget -->
            <xpath expr="//field[@name='tax_totals']" position="after">
                <field name="amount_received_untaxed" readonly="1" widget="monetary"/>
                <field name="amount_received_tax" readonly="1" widget="monetary"/>
                <field name="amount_received_total" readonly="1" widget="monetary"/>
            </xpath>

        </field>
    </record>

    <!-- Inherit the purchase order KPIs tree view -->
    <record id="view_purchase_order_kpis_tree_inherit_received_total" model="ir.ui.view">
        <field name="name">purchase.order.kpis.tree.inherit.received.total</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='origin']" position="after">
                <field name="amount_received_total" widget="monetary" optional="show" sum="Total Received"/>
                <field name="date_approve" optional="show"/>
                <field name="effective_date" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>